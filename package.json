{
  "name": "@rogerchappel/homebrew-tap",
  "version": "0.1.0",
  "private": true,
  "description": "Professional Homebrew tap catalog and validator for Roger Chappel's OSS tools.",
  "type": "module",
  "bin": {
    "tapring": "./src/cli.mjs"
  },
  "scripts": {
    "test": "node --test tests/*.test.mjs",
    "validate": "node src/cli.mjs validate",
    "catalog": "node src/cli.mjs catalog",
    "generate": "node src/cli.mjs generate",
    "check:readme": "node src/cli.mjs readme-check",
    "check:ruby": "ruby -c Formula/*.rb"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {}
}
